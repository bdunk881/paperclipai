# Microsoft Entra External ID (CIAM) configuration
# Copy this file to .env.local and fill in the values from Azure Portal.
#
# Azure Portal steps:
#   1. Create an Entra External ID (External) tenant at portal.azure.com
#   2. Register an application in that tenant as a Single-page application (SPA)
#      and add these redirect URIs:
#        - http://localhost:5173/auth/callback
#        - http://localhost:5173/login
#   3. Note the Application (client) ID and the tenant subdomain

# Application (client) ID from the app registration
VITE_AZURE_CIAM_CLIENT_ID=

# Tenant subdomain — the part before .ciamlogin.com
# e.g. if your tenant is "autoflowciam.ciamlogin.com", enter "autoflowciam"
VITE_AZURE_CIAM_TENANT_SUBDOMAIN=

# Tenant domain — the full .onmicrosoft.com domain
# e.g. "autoflowciam.onmicrosoft.com"
VITE_AZURE_CIAM_TENANT_DOMAIN=
