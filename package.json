{
  "name": "autoflow",
  "version": "0.1.0",
  "description": "AutoFlow — AI-powered workflow automation SaaS",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:templates": "jest src/templates",
    "test:api": "jest src/api",
    "test:engine": "jest src/engine"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@azure/identity": "^4.13.1",
    "@azure/keyvault-secrets": "^4.10.0",
    "@google/generative-ai": "^0.24.1",
    "@mistralai/mistralai": "^2.1.2",
    "@types/multer": "^2.1.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.2",
    "multer": "^2.1.1",
    "openai": "^6.33.0",
    "stripe": "^21.0.1",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.5",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dashboard/"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/index.ts",
      "!src/test-factories/**"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "functions": 80,
        "branches": 80,
        "statements": 80
      }
    },
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "forceExit": true
  }
}
