# Supabase Auth — backend JWT verification
# Backend API tokens are verified against the project's JWKS at
# <SUPABASE_URL>/auth/v1/.well-known/jwks.json.
SUPABASE_URL=
# Optional explicit audience allowlist. Defaults to `authenticated`.
SUPABASE_JWT_AUDIENCES=

# Native auth CORS proxy for the legacy CIAM SPA flows. This remains only until
# the frontend finishes the Supabase auth cutover.
AUTH_NATIVE_AUTH_PROXY_BASE_URL=
# Optional origin allowlist override. Falls back to ALLOWED_ORIGINS when unset.
AUTH_NATIVE_AUTH_PROXY_ALLOWED_ORIGINS=
# Optional tighter rate limit for unauthenticated native-auth proxy calls.
AUTH_NATIVE_AUTH_PROXY_RATE_LIMIT_MAX=20
AUTH_NATIVE_AUTH_PROXY_RATE_LIMIT_WINDOW_MS=60000

# Azure Blob Storage — used by content pipelines and automation agents
# Discovered via az CLI / Managed Identity; no connection string needed.
AZURE_STORAGE_ACCOUNT=altitudemediastorage

# Stripe — billing / checkout
# Test-mode secret key from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
# Stripe connector (OAuth / Connect) for Tier 1 rollout verification
STRIPE_CLIENT_ID=
STRIPE_CLIENT_SECRET=
STRIPE_REDIRECT_URI=
# Optional; defaults to "read_write"
STRIPE_OAUTH_SCOPE=
# Optional override; defaults to https://connect.stripe.com/oauth/authorize
STRIPE_OAUTH_AUTHORIZE_URL=
# Optional override; defaults to https://connect.stripe.com/oauth/token
STRIPE_OAUTH_TOKEN_URL=
# Stripe connector webhook verification secret
STRIPE_CONNECT_WEBHOOK_SECRET=
# Price IDs for recurring monthly plans (test mode)
STRIPE_FLOW_PRICE_ID=price_1TKPReLdsQqpbPtjXEIxgmvy
STRIPE_AUTOMATE_PRICE_ID=price_1TKPRmLdsQqpbPtjGdfkU3S7
STRIPE_SCALE_PRICE_ID=price_1TKPRmLdsQqpbPtjQJMYlOwN
# Webhook signing secret from Stripe dashboard
STRIPE_WEBHOOK_SECRET=

# Connector credentials encryption key (used by Slack/Shopify/DocuSign/Linear/PostHog connectors)
CONNECTOR_CREDENTIAL_ENCRYPTION_KEY=

# Slack connector
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=
# Optional; defaults to channels:read,chat:write,groups:read,channels:history,groups:history
SLACK_SCOPES=
SLACK_SIGNING_SECRET=

# HubSpot connector
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=
# Optional; defaults to contact/company/deal read+write scopes
HUBSPOT_SCOPES=
HUBSPOT_WEBHOOK_SECRET=

# Gmail connector
GMAIL_REDIRECT_URI=
# Optional; defaults to Gmail readonly/send/labels/modify scopes
GMAIL_SCOPES=
GMAIL_PUBSUB_TOPIC=
GMAIL_PUBSUB_AUDIENCE=
GMAIL_PUBSUB_SERVICE_ACCOUNT_EMAIL=

# Linear connector
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_REDIRECT_URI=
# Optional; defaults to "read,write"
LINEAR_SCOPES=
LINEAR_WEBHOOK_SECRET=

# Sentry error monitoring (Node backend)
# Project: node-backend @ autoflow-mo.sentry.io
SENTRY_DSN=https://e8f6106671fea4bc5f838a0522b093e5@o4511322232520704.ingest.us.sentry.io/4511322664730624
# Override environment tag in Sentry (defaults to NODE_ENV). Set to "staging" or "production".
SENTRY_ENVIRONMENT=

# Sentry connector (OAuth integration for ticket sync)
SENTRY_CLIENT_ID=
SENTRY_CLIENT_SECRET=
SENTRY_REDIRECT_URI=
# Optional; defaults to "org:read project:read event:read"
SENTRY_SCOPES=
SENTRY_WEBHOOK_SECRET=

# Microsoft Teams connector
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_REDIRECT_URI=
# Optional; defaults to "openid profile offline_access User.Read Chat.Read ChannelMessage.Read.All"
TEAMS_SCOPES=
# Optional; defaults to "common"
TEAMS_TENANT_ID=
TEAMS_WEBHOOK_CLIENT_STATE=

# PostHog connector
POSTHOG_CLIENT_ID=
POSTHOG_CLIENT_SECRET=
POSTHOG_REDIRECT_URI=
# Optional; defaults to "projects:read feature_flags:read events:write"
POSTHOG_SCOPES=
# Optional; defaults to "https://app.posthog.com/oauth"
POSTHOG_OAUTH_BASE_URL=
# Optional; defaults to "https://app.posthog.com"
POSTHOG_API_BASE_URL=
# Optional; defaults to "https://us.i.posthog.com"
POSTHOG_CAPTURE_BASE_URL=
POSTHOG_WEBHOOK_SECRET=

# Intercom connector
INTERCOM_CLIENT_ID=
INTERCOM_CLIENT_SECRET=
INTERCOM_REDIRECT_URI=
# Optional; defaults to "read_conversations read_contacts write_contacts write_conversations"
INTERCOM_SCOPES=
# Optional; defaults to "https://app.intercom.com/oauth"
INTERCOM_OAUTH_AUTHORIZE_URL=
# Optional; defaults to "https://api.intercom.io/auth/eagle"
INTERCOM_OAUTH_TOKEN_BASE_URL=
# Optional; defaults to "https://api.intercom.io"
INTERCOM_API_BASE_URL=
# Optional; defaults to "2.13"
INTERCOM_API_VERSION=
INTERCOM_WEBHOOK_SECRET=

# Apollo connector
APOLLO_CLIENT_ID=
APOLLO_CLIENT_SECRET=
APOLLO_REDIRECT_URI=
# Optional; defaults to "read_user_profile"
APOLLO_SCOPES=
# Optional; defaults to "https://app.apollo.io/#/oauth/authorize"
APOLLO_OAUTH_AUTHORIZE_URL=
# Optional; defaults to "https://app.apollo.io/api/v1/oauth/token"
APOLLO_OAUTH_TOKEN_URL=
# Optional; required for Apollo inbound webhook verification flows
APOLLO_WEBHOOK_SECRET=

# DocuSign connector
DOCUSIGN_CLIENT_ID=
DOCUSIGN_CLIENT_SECRET=
DOCUSIGN_REDIRECT_URI=
# Optional; defaults to "signature extended offline_access"
DOCUSIGN_SCOPES=
# Optional; defaults to "https://account-d.docusign.com/oauth"
DOCUSIGN_OAUTH_BASE_URL=
DOCUSIGN_WEBHOOK_SECRET=

# Optional staging-only QA bypass for run execution/retrieval endpoints.
# Enable only in non-production verification environments and restrict to allowlisted IDs.
QA_AUTH_BYPASS_ENABLED=false
QA_AUTH_BYPASS_USER_IDS=qa-smoke-user

# Social auth for staging bypass flows
# Google OAuth app credentials used by Passport social login in staging.
# `GOOGLE_CLIENT_ID` may also be supplied as a deployment environment variable.
# First release is Google-only; Facebook and Apple can be added later using the same route pattern.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Symmetric signing key for app-issued session JWTs used alongside Entra tokens.
APP_JWT_SECRET=
# Session lifetime for app-issued JWTs used by social auth and QA preview access.
APP_JWT_EXPIRES_IN=8h
# Google OAuth console settings for staging:
# - Authorized JavaScript origins: https://staging.app.helloautoflow.com
# - Authorized redirect URI: https://staging-api.helloautoflow.com/api/auth/social/google/callback
# Optional override when the default `SOCIAL_AUTH_CALLBACK_BASE_URL/google/callback`
# callback shape does not match the deployed ingress.
GOOGLE_CALLBACK_URL=
# Base callback prefix for social providers, expected staging value:
# https://staging-api.helloautoflow.com/api/auth/social
SOCIAL_AUTH_CALLBACK_BASE_URL=
# Default dashboard target when the caller does not provide an approved redirect_uri:
# https://staging.app.helloautoflow.com
SOCIAL_AUTH_DASHBOARD_URL=
# Optional social redirect allowlist override. Falls back to ALLOWED_ORIGINS when unset.
# Expected staging value: https://staging.app.helloautoflow.com
AUTH_SOCIAL_ALLOWED_REDIRECT_ORIGINS=
