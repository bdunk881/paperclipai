# Microsoft Entra External ID — backend JWT verification
# These must match the tenant and app registration used by the frontend.

# Application (client) ID — used as the expected JWT audience
AZURE_CLIENT_ID=

# Directory (tenant) ID — GUID from Azure Portal > tenant overview
AZURE_TENANT_ID=

# Tenant subdomain — same as VITE_AZURE_TENANT_SUBDOMAIN in dashboard/.env.local
AZURE_TENANT_SUBDOMAIN=

# CORS — comma-separated list of allowed frontend origins (required in production)
# Example: ALLOWED_ORIGINS=https://app.autoflow.io,https://dashboard.autoflow.io
ALLOWED_ORIGINS=

# LLM config encryption key — used to encrypt stored API keys at rest.
# Generate with: openssl rand -hex 32
# If unset, a random key is generated per process (keys are lost on restart).
LLM_CONFIG_ENCRYPTION_KEY=
