VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_USE_MOCK=false
VITE_SENTRY_DSN=
# Override environment tag in Sentry. Set to "staging" or "production" in Vercel env vars.
# Defaults to Vite's MODE (usually "production" for all Vercel builds).
VITE_SENTRY_ENVIRONMENT=
# Sentry source map upload token — required for production/staging builds
# Get from https://autoflow-mo.sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=
