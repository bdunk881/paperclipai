# Azure Blob Storage
# Name of the Azure Storage Account used for blob storage (no hardcoded fallback — required).
AZURE_STORAGE_ACCOUNT_NAME=

# Microsoft Entra External ID — backend JWT verification
# These must match the tenant and app registration used by the frontend.

# Application (client) ID — used as the expected JWT audience
AZURE_CLIENT_ID=

# Directory (tenant) ID — GUID from Azure Portal > tenant overview
AZURE_TENANT_ID=

# Tenant subdomain — same as VITE_AZURE_TENANT_SUBDOMAIN in dashboard/.env.local
AZURE_TENANT_SUBDOMAIN=
