{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https://cdn.helloautoflow.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://api.helloautoflow.com https://staging-api.helloautoflow.com https://*.ciamlogin.com https://login.microsoftonline.com https://fonts.googleapis.com https://cdn.helloautoflow.com https://*.sentry.io https://*.ingest.us.sentry.io; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Document-Policy",
          "value": "js-profiling"
        },
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "on"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path((?!billing/checkout$|create-checkout-session$|qa-preview-access$|waitlist-signup$).*)",
      "has": [
        {
          "type": "host",
          "value": "staging.app.helloautoflow.com"
        }
      ],
      "destination": "https://staging-api.helloautoflow.com/api/:path*"
    },
    {
      "source": "/api/:path((?!billing/checkout$|create-checkout-session$|qa-preview-access$|waitlist-signup$).*)",
      "destination": "https://api.helloautoflow.com/api/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
