# Microsoft Entra External ID (CIAM) configuration
# Copy this file to .env.local and fill in the values from Azure Portal.
#
# Azure Portal steps:
#   1. Create an Entra External ID (External) tenant at portal.azure.com
#   2. Register an application in that tenant (SPA, redirect URI = http://localhost:5173)
#   3. Note the Application (client) ID and the tenant subdomain

# Application (client) ID from the app registration
VITE_AZURE_CLIENT_ID=

# Tenant subdomain — the part before .ciamlogin.com
# e.g. if your tenant is "autoflow.ciamlogin.com", enter "autoflow"
VITE_AZURE_TENANT_SUBDOMAIN=
