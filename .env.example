# ─── Required secrets (no defaults — docker-compose will fail without these) ──
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Redis auth password — required in all environments
# Generate with: openssl rand -base64 32
REDIS_PASSWORD=

# PostgreSQL password — required; used by the postgres container and DATABASE_URL
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=

# ─── Database connection ───────────────────────────────────────────────────────
# Must be set when POSTGRES_PASSWORD is non-default.
# Format: postgresql://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql://autoflow:<POSTGRES_PASSWORD>@postgres:5432/autoflow

# ─── Optional overrides (have safe defaults) ──────────────────────────────────
# ENV: development | production | test
ENV=development

# Override postgres user/db if needed (defaults to "autoflow")
# POSTGRES_USER=autoflow
# POSTGRES_DB=autoflow

# Override full Redis URL if not using the default compose redis service
# REDIS_URL=redis://:<REDIS_PASSWORD>@redis:6379

# ─── Microsoft Entra External ID — backend JWT verification ───────────────────
# These must match the tenant and app registration used by the frontend.

# Application (client) ID — used as the expected JWT audience
AZURE_CLIENT_ID=

# Directory (tenant) ID — GUID from Azure Portal > tenant overview
AZURE_TENANT_ID=

# Tenant subdomain — same as VITE_AZURE_TENANT_SUBDOMAIN in dashboard/.env.local
AZURE_TENANT_SUBDOMAIN=
