# Microsoft Entra External ID (CIAM) configuration
# Copy this file to .env.local and fill in the values from Azure Portal.
#
# Tenant: Autoflowciam.onmicrosoft.com  (Tenant ID: 5e4f1080-8afc-4005-b05e-32b21e69363a)
# App registration: autoflow-dashboard  (Client ID: f0c4b48e-9052-43d6-a3e6-c5c65ba18ad7)

# CIAM app registration client ID
# Value: f0c4b48e-9052-43d6-a3e6-c5c65ba18ad7
VITE_AZURE_CIAM_CLIENT_ID=

# CIAM tenant subdomain — the part before .ciamlogin.com
# Value: Autoflowciam
VITE_AZURE_CIAM_TENANT_SUBDOMAIN=

# Optional: tenant domain path segment used in authority URL.
# Defaults to "<VITE_AZURE_CIAM_TENANT_SUBDOMAIN>.onmicrosoft.com" when omitted.
# Value for this tenant: Autoflowciam.onmicrosoft.com
# VITE_AZURE_CIAM_TENANT_DOMAIN=
