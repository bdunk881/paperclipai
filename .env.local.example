# Local-only secrets for docker-compose development.
# Copy to .env.local and fill in real values.

# App signing/encryption secret used by backend.
SECRET_KEY=replace-with-a-long-random-secret

# Postgres password for local container boot.
POSTGRES_PASSWORD=replace-with-a-strong-password

# Optional: local DB/Redis connection overrides if needed.
DATABASE_URL=postgresql://autoflow:${POSTGRES_PASSWORD}@postgres:5432/autoflow
REDIS_URL=redis://redis:6379

# Sentry Node backend DSN (optional locally — leave blank to disable)
SENTRY_DSN=

# In-memory store fallback (HEL-80, double-locked production safety).
# Set to "true" alongside NODE_ENV=development/test to allow stores to fall
# back to process-local storage when DATABASE_URL is unreachable. Production
# deploys must NEVER set this — bootstrap.ts will refuse to start if Postgres
# is configured but unreachable while NODE_ENV=production.
AUTOFLOW_ALLOW_INMEMORY=true
