{
  "name": "autoflow-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "infisical run --env=dev -- vite",
    "dev:no-secrets": "vite",
    "build": "tsc && vite build",
    "build:swa": "npm run build && node scripts/render-static-webapp-config.mjs",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:auth-regression": "playwright test e2e/auth-regression.spec.ts",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "@sentry/react": "^10.51.0",
    "@supabase/supabase-js": "^2.105.3",
    "@xyflow/react": "^12.10.2",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.2",
    "stripe": "^21.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.1",
    "@sentry/vite-plugin": "^5.2.1",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.11.5",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "@vercel/node": "^5.7.15",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "~0.4.7",
    "jsdom": "^24.1.3",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.2.2",
    "vite": "^7.1.4",
    "vitest": "^4.1.5"
  }
}
