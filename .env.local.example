# Local-only secrets for docker-compose development.
# Copy to .env.local and fill in real values.

# App signing/encryption secret used by backend.
SECRET_KEY=replace-with-a-long-random-secret

# Postgres password for local container boot.
POSTGRES_PASSWORD=replace-with-a-strong-password

# Optional: local DB/Redis connection overrides if needed.
DATABASE_URL=postgresql://autoflow:${POSTGRES_PASSWORD}@postgres:5432/autoflow
REDIS_URL=redis://redis:6379
